# Supabase URL & Anon Key for database/auth/functions
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Dodo Payments — set these as Supabase EDGE FUNCTION SECRETS, not in the client.
#   supabase secrets set DODO_API_KEY=... (see comment block in README/below)
# These are NOT VITE_ vars: payment logic runs server-side in the edge functions.
# ─────────────────────────────────────────────────────────────────────────────
# DODO_API_KEY=your_dodo_api_key
# DODO_ENVIRONMENT=test_mode            # test_mode | live_mode
# DODO_WEBHOOK_SECRET=whsec_...         # Standard-Webhooks signing secret
# DODO_DEFAULT_COUNTRY=US               # default billing country (editable on the hosted page)
# APP_URL=http://localhost:8080         # used to build the post-checkout return_url
#
# One Dodo product id per plan × billing cycle:
# DODO_PRODUCT_STARTER_MONTHLY=prod_...
# DODO_PRODUCT_STARTER_ANNUAL=prod_...
# DODO_PRODUCT_CREATOR_MONTHLY=prod_...
# DODO_PRODUCT_CREATOR_ANNUAL=prod_...
# DODO_PRODUCT_PRO_MONTHLY=prod_...
# DODO_PRODUCT_PRO_ANNUAL=prod_...
